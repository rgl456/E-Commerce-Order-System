{
  "title": "Microservices Overview",
  "uid": "microservices-overview",
  "panels": [
    {
      "title": "Request Rate (req/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (application)",
        "legendFormat": "{{application}}"
      }]
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{status=~'5..'}[1m])) by (application) / sum(rate(http_server_requests_seconds_count[1m])) by (application) * 100",
        "legendFormat": "{{application}} error %"
      }]
    },
    {
      "title": "p99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[1m])) by (le, application)) * 1000",
        "legendFormat": "{{application}} p99"
      }]
    },
    {
      "title": "Circuit Breaker States",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "resilience4j_circuitbreaker_state",
        "legendFormat": "{{name}} - {{state}}"
      }]
    },
    {
      "title": "Orders Created / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [{
        "expr": "rate(orders_created_total[1m]) * 60",
        "legendFormat": "orders/min"
      }]
    },
    {
      "title": "Order Failure Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [{
        "expr": "rate(orders_failed_total[5m]) / rate(orders_created_total[5m]) * 100",
        "legendFormat": "failure %"
      }]
    },
    {
      "title": "Active Order Processing",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [{
        "expr": "orders_processing_active",
        "legendFormat": "active"
      }]
    },
    {
      "title": "JVM Heap Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "expr": "jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'} * 100",
        "legendFormat": "{{application}} heap %"
      }]
    },
    {
      "title": "Active HTTP Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "expr": "tomcat_threads_busy_threads",
        "legendFormat": "{{application}} busy threads"
      }]
    }
  ]
}